# Model/runtime knobs cho provider thật.
LUMI_ASR_MODEL=vinai/PhoWhisper-large
LUMI_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LUMI_SPEAKER_MODEL=speechbrain/spkrec-ecapa-voxceleb

# MVP provider defaults: model-first.
LUMI_ASR_PROVIDER=phowhisper
LUMI_RESPONSE_PROVIDER=qwen
LUMI_TTS_PROVIDER=vieneu
LUMI_TTS_MODE=v3turbo
LUMI_TTS_VOICE=
LUMI_LLM_MAX_NEW_TOKENS=180
LUMI_LLM_TEMPERATURE=0.55
LUMI_OUTPUT_DIR=outputs
# Mặc định để trống sẽ lưu theo ngày, ví dụ outputs/20260626.
# Khi chạy thử local muốn gom file vào một chỗ: LUMI_OUTPUT_SUBDIR=test
LUMI_OUTPUT_SUBDIR=
LUMI_CUDA_VISIBLE_DEVICES=1

# Hành vi demo cũ / hook tương lai.
LUMI_OWNER_NAME=bạn
LUMI_SILENCE_SECONDS=1.5
LUMI_DEBUG=1

FROM node:20-alpine AS build

WORKDIR /app
COPY echo-presence-ai/package*.json ./
RUN npm install
COPY echo-presence-ai/ ./

# Đổi URL API từ 127.0.0.1 sang relative path để gọi đúng qua Nginx
RUN sed -i 's|"http://127.0.0.1:8765"|""|g' src/ai/pipeline.ts

RUN npm run build

FROM nginx:alpine
# Copy code frontend đã build vào Nginx
COPY --from=build /app/dist /usr/share/nginx/html
# Copy cấu hình proxy
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]

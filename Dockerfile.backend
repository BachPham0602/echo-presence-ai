FROM python:3.10-slim

WORKDIR /app

# Cài đặt các thư viện hệ thống cần thiết cho âm thanh (PortAudio, FFmpeg)
RUN apt-get update && apt-get install -y \
    build-essential \
    libportaudio2 \
    portaudio19-dev \
    git \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Copy mã nguồn và cấu hình
COPY pyproject.toml README.md /app/
COPY src/ /app/src/

# Copy ZipVoice từ named build context trong docker-compose.yml.
COPY --from=vizipvoice zipvoice/ /app/zipvoice/
COPY --from=vizipvoice requirements-tts-runtime.txt /tmp/vizipvoice-requirements.txt

# Cài đặt dependency (bao gồm llm, tts, asr, audio, speaker) và runtime cho ZipVoice.
RUN pip install --no-cache-dir -e '.[llm,tts,asr,audio]' \
    && pip install --no-cache-dir -r /tmp/vizipvoice-requirements.txt \
    && pip install --no-cache-dir 'huggingface_hub>=1.21.0'

EXPOSE 8765

# Chạy server
CMD ["python", "-m", "lumi.web_app", "--host", "0.0.0.0", "--port", "8765"]
